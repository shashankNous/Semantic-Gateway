# Upstream LLM (Mistral) used to answer cache misses
MISTRAL_API_KEY=your-mistral-api-key
UPSTREAM_BASE_URL=https://api.mistral.ai/v1
UPSTREAM_MODEL=mistral-small-latest

# Embeddings provider used for the semantic cache
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=your-openai-api-key

# Redis (exact-match cache)
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=86400

# Postgres (request logging + pgvector semantic cache)
# POSTGRES_PASSWORD is consumed directly by docker-compose.yml to configure the postgres container.
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/semanticdb

# Semantic cache
SEMANTIC_CACHE_THRESHOLD=0.92

# Stats endpoint cost estimation
COST_PER_1K_TOKENS=0.002
